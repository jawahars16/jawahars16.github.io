---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Articles — jawahar.dev"
  description="Technical articles on distributed systems, cloud infrastructure, Go, and software engineering by Jawahar S."
  canonical="https://jawahar.dev/articles/"
>
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-2xl font-bold tracking-tight mb-2" style="color: #f8f8f2;">Articles</h1>
    <p class="text-sm font-mono mb-10 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md" style="color: #bd93f9; background: rgba(189,147,249,0.1); border: 1px solid rgba(189,147,249,0.2);">{posts.length} posts</p>

    <!--
      To add a new article:
      1. Create src/content/blog/your-slug.md with frontmatter: title, date, description, tags
      2. The URL will automatically be /articles/your-slug/
    -->

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
      {posts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          slug={post.slug}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  </div>
</BaseLayout>
