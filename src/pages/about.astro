---
import BaseLayout from '../layouts/BaseLayout.astro';

const bioLines = [
  { n: 1,  t: "Hi, I'm Jawahar — a software engineer focused on" },
  { n: 2,  t: "backend systems and distributed computing." },
  { n: 3,  t: "" },
  { n: 4,  t: "I spend most of my time thinking about how systems" },
  { n: 5,  t: "fail, how to make them not fail, and how to explain" },
  { n: 6,  t: "those ideas clearly." },
  { n: 7,  t: "" },
  { n: 8,  t: "This site is where I publish long-form articles," },
  { n: 9,  t: "short visual explainers (Bytes), and videos. Topics" },
  { n: 10, t: "include distributed systems, cloud platforms, system" },
  { n: 11, t: "design, and the engineering practices that make" },
  { n: 12, t: "codebases maintainable." },
];

const skills = [
  "Go", "TypeScript", "Rust", "Python",
  "GCP", "AWS", "Azure",
  "Distributed Systems", "System Design", "Observability",
];

const links = [
  {
    label: "GitHub",
    handle: "@jawahars16",
    href: "https://github.com/jawahars16",
    icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z',
    color: '#f8f8f2',
  },
  {
    label: "YouTube",
    handle: "@jawahars16",
    href: "https://www.youtube.com/@jawahars16",
    icon: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
    color: '#ff5555',
  },
  {
    label: "LinkedIn",
    handle: "jawahars16",
    href: "https://linkedin.com/in/jawahars16",
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
    color: '#0a66c2',
  },
];
---

<BaseLayout
  title="About — jawahar.dev"
  description="Jawahar S is a software engineer focused on distributed systems, backend infrastructure, and cloud engineering."
  canonical="https://jawahar.dev/about/"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">

    <!-- Profile pic — floats above IDE -->
    <div class="flex flex-col items-center mb-[-28px] relative z-20">
      <div
        class="w-20 h-20 rounded-full flex items-center justify-center text-xl font-bold text-white select-none"
        style="background: linear-gradient(135deg, #6366f1, #a855f7); box-shadow: 0 0 0 3px #282a36, 0 0 0 5px #6366f1, 0 8px 32px rgba(99,102,241,0.45);"
      >
        JS
      </div>
    </div>

    <!-- IDE Window -->
    <div class="rounded-xl overflow-hidden shadow-2xl" style="border: 1px solid #44475a; background: #1e1f2e;">

      <!-- Title bar — traffic lights only -->
      <div class="flex items-center px-4 h-11" style="background: #21222c; border-bottom: 1px solid #44475a;">
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full bg-red-500"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
          <span class="w-3 h-3 rounded-full bg-green-500"></span>
        </div>
      </div>

      <!-- Single tab -->
      <div class="flex" style="background: #21222c; border-bottom: 1px solid #44475a;">
        <div class="flex items-center gap-1.5 px-4 py-2 text-xs font-mono" style="color: #f8f8f2; background: #1e1f2e; border-top: 1px solid #6366f1; border-right: 1px solid #44475a;">
          <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#8be9fd;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          about.ts
        </div>
      </div>

      <!-- Editor: plain text bio with line numbers -->
      <div class="overflow-x-auto py-5" style="background: #1e1f2e;">
        <table class="w-full border-collapse" style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; line-height: 1.85;">
          {bioLines.map(line => (
            <tr class="group hover:bg-white/[0.03] transition-colors">
              <td class="select-none text-right pr-5 pl-4 align-top group-hover:text-zinc-500 transition-colors" style="color: #44475a; min-width: 3.5rem; user-select: none; width: 3.5rem;">
                {line.n}
              </td>
              <td class="pr-8 align-top" style="color: #cdd6f4; white-space: pre-wrap;">
                {line.t || <span>&nbsp;</span>}
              </td>
            </tr>
          ))}
          <!-- Blinking cursor -->
          <tr>
            <td class="select-none text-right pr-5 pl-4" style="color: #44475a;">13</td>
            <td><span class="inline-block w-2 h-4 align-middle" style="background: #cdd6f4; animation: blink 1.1s step-end infinite;"></span></td>
          </tr>
        </table>
      </div>

      <!-- Status bar -->
      <div class="flex items-center justify-between px-4 h-7 text-xs font-mono" style="background: linear-gradient(135deg, #4f46e5, #7c3aed); color: rgba(255,255,255,0.85);">
        <div class="flex items-center gap-4">
          <span>⎇ main</span>
          <span>⚡ 0 errors</span>
        </div>
        <div class="flex items-center gap-4">
          <span>Ln 12, Col 1</span>
          <span>UTF-8</span>
          <span>TypeScript</span>
        </div>
      </div>
    </div>

    <!-- Skills -->
    <div class="mt-10">
      <h2 class="text-xs font-mono uppercase tracking-widest mb-4" style="color: #44475a;">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map(s => (
          <span class="text-xs font-mono px-3 py-1.5 rounded-full" style="background: rgba(99,102,241,0.12); color: #bd93f9; border: 1px solid rgba(99,102,241,0.25);">
            {s}
          </span>
        ))}
      </div>
    </div>

    <!-- Links -->
    <div class="mt-10">
      <h2 class="text-xs font-mono uppercase tracking-widest mb-4" style="color: #44475a;">Links</h2>
      <div class="flex flex-col sm:flex-row gap-3">
        {links.map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener"
            class="flex items-center gap-3 px-4 py-3 rounded-xl flex-1 transition-all duration-200 hover:scale-[1.02]"
            style="background: #21222c; border: 1px solid #44475a;"
            onmouseover={`this.style.borderColor='${link.color}55'`}
            onmouseout="this.style.borderColor='#44475a'"
          >
            <span class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style={`background: ${link.color}18;`}>
              <svg class="w-4 h-4" fill="currentColor" style={`color: ${link.color};`} viewBox="0 0 24 24">
                <path d={link.icon}/>
              </svg>
            </span>
            <div>
              <div class="text-sm font-mono font-semibold" style="color: #f8f8f2;">{link.label}</div>
              <div class="text-xs font-mono" style="color: #6272a4;">{link.handle}</div>
            </div>
            <svg class="w-3.5 h-3.5 ml-auto flex-shrink-0" style="color: #44475a;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
