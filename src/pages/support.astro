---
import BaseLayout from '../layouts/BaseLayout.astro';

const appConfigs = {
  joy: {
    name: 'Joy: Celebrate Your Wins',
    sentryDsn: import.meta.env.JOY_PUBLIC_SENTRY_DSN ?? '',
  },
};
---

<BaseLayout
  title="Support — jawahar.sh"
  description="Contact app support."
  canonical="https://jawahar.sh/support/"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <section class="rounded-xl overflow-hidden shadow-2xl" style="border: 1px solid #44475a; background: #1e1f2e;">
      <div class="flex items-center justify-between px-4 h-11" style="background: #21222c; border-bottom: 1px solid #44475a;">
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full bg-red-500"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
          <span class="w-3 h-3 rounded-full bg-green-500"></span>
        </div>
        <span class="text-xs font-mono" style="color: #6272a4;">How can I help?</span>
      </div>

      <div class="flex" style="background: #21222c; border-bottom: 1px solid #44475a;">
        <div class="flex items-center gap-1.5 px-4 py-2 text-xs font-mono" style="color: #f8f8f2; background: #1e1f2e; border-top: 1px solid #6366f1; border-right: 1px solid #44475a;">
          <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#8be9fd;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 4v-4z"/>
          </svg>
          support.form
        </div>
      </div>

      <div class="px-5 py-7 sm:px-7">
        <div class="mb-7">
          <p id="support-kicker" class="text-xs font-mono uppercase tracking-widest mb-3" style="color: #bd93f9; letter-spacing: 0.12em;">Support</p>
          <h1 class="text-2xl font-bold tracking-tight mb-3" style="color: #f8f8f2;">How can I help?</h1>
          <p id="support-intro" class="text-sm leading-relaxed max-w-2xl" style="color: #6272a4;">
            Send a note. Include your email only if you need a reply.
          </p>
        </div>

        <form id="support-form" class="space-y-5" data-app-configs={JSON.stringify(appConfigs)}>
          <div id="app-field" hidden>
            <label for="app" class="block text-sm font-mono font-semibold mb-2" style="color: #f8f8f2;">App</label>
            <input
              id="app"
              name="app"
              type="text"
              readonly
              disabled
              class="w-full rounded-lg px-4 py-3 text-sm font-mono outline-none transition-colors"
              style="background: #21222c; border: 1px solid #44475a; color: #f8f8f2;"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-mono font-semibold mb-2" style="color: #f8f8f2;">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="7"
              minlength="10"
              placeholder="Tell me what happened, what you expected, and anything that may help reproduce it."
              class="w-full rounded-lg px-4 py-3 text-sm font-mono leading-relaxed outline-none transition-colors resize-y"
              style="background: #282a36; border: 1px solid #44475a; color: #f8f8f2;"
            ></textarea>
          </div>

          <div>
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
              <label for="email" class="block text-sm font-mono font-semibold" style="color: #f8f8f2;">Email</label>
              <span class="text-xs font-mono" style="color: #ffb86c;">Optional, needed for a reply</span>
            </div>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full rounded-lg px-4 py-3 text-sm font-mono outline-none transition-colors"
              style="background: #282a36; border: 1px solid #44475a; color: #f8f8f2;"
            />
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-2">
            <button
              id="support-submit"
              type="submit"
              class="inline-flex items-center justify-center rounded-lg px-5 py-3 text-sm font-mono font-semibold transition-all duration-200 hover:scale-[1.02] disabled:cursor-not-allowed disabled:opacity-60 disabled:hover:scale-100"
              style="background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white; box-shadow: 0 8px 24px rgba(99,102,241,0.28);"
            >
              Send
            </button>
            <p id="support-status" role="status" aria-live="polite" class="text-sm font-mono min-h-5" style="color: #6272a4;"></p>
          </div>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector('#support-form');
  const appField = document.querySelector('#app-field');
  const appInput = document.querySelector('#app');
  const supportKicker = document.querySelector('#support-kicker');
  const supportIntro = document.querySelector('#support-intro');
  const submitButton = document.querySelector('#support-submit');
  const status = document.querySelector('#support-status');
  const appConfigs = JSON.parse(form?.dataset.appConfigs || '{}');

  const requestedApp = new URLSearchParams(window.location.search).get('app')?.toLowerCase();
  const appConfig = requestedApp ? appConfigs[requestedApp] : undefined;
  const appName = appConfig?.name;

  if (appName && appField && appInput) {
    appInput.value = appName;
    appInput.disabled = false;
    appField.hidden = false;

    if (supportKicker) {
      supportKicker.textContent = 'App Support';
    }

    if (supportIntro) {
      supportIntro.textContent = 'Send a note about the app. Include your email only if you need a reply.';
    }
  }

  const getEventId = () => {
    const bytes = new Uint8Array(16);
    crypto.getRandomValues(bytes);
    return Array.from(bytes, byte => byte.toString(16).padStart(2, '0')).join('');
  };

  const getEnvelopeEndpoint = dsn => {
    const parsed = new URL(dsn);
    const projectId = parsed.pathname.split('/').filter(Boolean).at(-1);
    const publicKey = parsed.username;

    if (!projectId || !publicKey) {
      throw new Error('Invalid Sentry DSN');
    }

    const auth = new URLSearchParams({
      sentry_key: publicKey,
      sentry_version: '7',
      sentry_client: 'jawahar-support/1.0',
    });

    return `${parsed.protocol}//${parsed.host}/api/${projectId}/envelope/?${auth.toString()}`;
  };

  const sendFeedback = async ({ dsn, app, message, email }) => {
    const eventId = getEventId();
    const now = new Date().toISOString();
    const feedback = {
      event_id: eventId,
      timestamp: now,
      platform: 'javascript',
      level: 'info',
      type: 'feedback',
      contexts: {
        feedback: {
          message,
          contact_email: email || undefined,
          name: email || 'Anonymous support request',
          source: 'jawahar.sh/support',
          url: window.location.href,
          app: app || undefined,
        },
      },
      tags: {
        app: app || 'generic',
        source: 'support-page',
      },
    };

    const envelope = [
      JSON.stringify({
        event_id: eventId,
        dsn,
        sent_at: now,
        sdk: { name: 'jawahar-support', version: '1.0' },
      }),
      JSON.stringify({ type: 'feedback', content_type: 'application/json' }),
      JSON.stringify(feedback),
    ].join('\n');

    const response = await fetch(getEnvelopeEndpoint(dsn), {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-sentry-envelope' },
      body: envelope,
    });

    if (!response.ok) {
      throw new Error('Sentry rejected the support request');
    }

    return eventId;
  };

  form?.addEventListener('submit', async event => {
    event.preventDefault();

    const data = new FormData(form);
    const dsn = appConfig?.sentryDsn?.trim();
    const app = data.get('app')?.toString() ?? '';
    const message = data.get('message')?.toString().trim() ?? '';
    const email = data.get('email')?.toString().trim() ?? '';

    if (!dsn) {
      status.textContent = 'Support is not configured yet. Please try again later.';
      status.style.color = '#ff5555';
      return;
    }

    submitButton.disabled = true;
    submitButton.textContent = 'Sending...';
    status.textContent = '';

    try {
      await sendFeedback({ dsn, app, message, email });
      form.reset();
      status.textContent = email
        ? 'Thanks, your message was sent. I will reply by email if needed.'
        : 'Thanks, your message was sent.';
      status.style.color = '#50fa7b';
    } catch {
      status.textContent = 'Something went wrong while sending. Please try again.';
      status.style.color = '#ff5555';
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = 'Send';
    }
  });
</script>
