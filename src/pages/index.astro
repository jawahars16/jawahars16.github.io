---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// --- YouTube: fetch 3 most recent long-form videos ---
const CHANNEL_ID = 'UCmMu15DUGT3klr0M6RBQqbg';
const CHANNEL_URL = 'https://www.youtube.com/channel/UCmMu15DUGT3klr0M6RBQqbg/videos';

function decodeEntities(str: string): string {
  return str
    .replace(/&amp;/g, '&').replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'");
}

interface Video { id: string; title: string; description: string; published: string; formattedDate: string; thumbnail: string; url: string; }

let recentVideos: Video[] = [];
try {
  const rss = await fetch(`https://www.youtube.com/feeds/videos.xml?channel_id=${CHANNEL_ID}`);
  const xml = await rss.text();
  const entries = xml.match(/<entry>([\s\S]*?)<\/entry>/g) ?? [];

  const parsed: Video[] = entries.map(entry => {
    const id    = entry.match(/<yt:videoId>(.*?)<\/yt:videoId>/)?.[1] ?? '';
    const title = decodeEntities(entry.match(/<title>([\s\S]*?)<\/title>/)?.[1]?.trim() ?? '');
    const pub   = entry.match(/<published>(.*?)<\/published>/)?.[1] ?? '';
    const desc  = decodeEntities((entry.match(/<media:description>([\s\S]*?)<\/media:description>/)?.[1] ?? '').trim()).slice(0, 120);
    const date  = new Date(pub);
    return {
      id, title, description: desc,
      published: pub.slice(0, 10),
      formattedDate: isNaN(date.getTime()) ? pub.slice(0, 10) : date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
      thumbnail: `https://i.ytimg.com/vi/${id}/hqdefault.jpg`,
      url: `https://www.youtube.com/watch?v=${id}`,
    };
  }).filter(v => v.id);

  const checkIsShort = async (id: string) => {
    try { const r = await fetch(`https://www.youtube.com/shorts/${id}`, { redirect: 'follow' }); return r.url.includes('/shorts/'); }
    catch { return false; }
  };
  const shortFlags = await Promise.all(parsed.map(v => checkIsShort(v.id)));
  recentVideos = parsed.filter((_, i) => !shortFlags[i]).slice(0, 3);
} catch { /* silently skip if RSS unavailable */ }

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jawahar S',
  url: 'https://jawahar.dev/',
  sameAs: ['https://github.com/jawahars16', 'https://www.youtube.com/@jawahars16'],
  jobTitle: 'Software Engineer',
};
---

<BaseLayout
  title="Jawahar S — Software Engineer"
  description="Software engineer writing about distributed systems, cloud infrastructure, Go, and the engineering ideas that make systems more reliable."
  jsonLd={jsonLd}
>
  <div class="max-w-5xl mx-auto px-6">

    <!-- Hero -->
    <section class="pt-10 pb-10" style="border-bottom: 1px solid #2d2f3f;">
      <div class="flex flex-col lg:flex-row items-center gap-10">

        <!-- Left: name, role, tagline, socials -->
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left flex-1 gap-5">
          <div>
            <h1 class="text-3xl font-bold tracking-tight mb-2" style="color: #f8f8f2;">Jawahar Selvaraj</h1>
            <p class="text-base font-mono" style="color: #8be9fd;">Software Engineer</p>
          </div>
          <p class="text-sm leading-relaxed max-w-xs" style="color: #6272a4;">
            Writing about distributed systems, cloud infrastructure, Go, and the engineering ideas that make software reliable.
          </p>
          <!-- Social links -->
          <div class="flex items-center gap-4 text-sm font-mono">
            <a href="https://github.com/jawahars16" target="_blank" rel="noopener"
              class="flex items-center gap-1.5 transition-colors hover:text-zinc-100" style="color: #6272a4;">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              GitHub
            </a>
            <a href="https://www.youtube.com/@jawahars16" target="_blank" rel="noopener"
              class="flex items-center gap-1.5 transition-colors hover:text-red-400" style="color: #6272a4;">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              YouTube
            </a>
            <a href="/about/" class="transition-colors hover:text-zinc-100" style="color: #6272a4;">About →</a>
          </div>
        </div>

        <!-- Right: terminal card -->
        <div class="w-full lg:w-auto lg:flex-1 max-w-xl">
          <div class="rounded-xl overflow-hidden shadow-xl" style="background: #1e1f2e; border: 1px solid rgba(255,255,255,0.22);">
            <div class="flex items-center px-4 py-2.5" style="background: #21222c; border-bottom: 1px solid #44475a;">
              <div class="flex items-center gap-1.5">
                <span class="w-3 h-3 rounded-full bg-red-500"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                <span class="w-3 h-3 rounded-full bg-green-500"></span>
                <span class="ml-2 text-xs font-mono" style="color: #44475a;">about.ts</span>
              </div>
            </div>
            <div class="px-5 py-5 font-mono text-sm leading-7">
              <div>
                <span style="color: #ff7b72;">const</span>
                <span style="color: #f8f8f2;"> about</span>
                <span style="color: #44475a;"> = </span>
                <span style="color: #f8f8f2;">&#123;</span>
              </div>
              <div class="pl-5">
                <span style="color: #79c0ff;">name</span><span style="color: #f8f8f2;">: </span>
                <span style="color: #ffb86c;">"Jawahar Selvaraj"</span><span style="color: #6272a4;">,</span>
              </div>
              <div class="pl-5">
                <span style="color: #79c0ff;">role</span><span style="color: #f8f8f2;">: </span>
                <span style="color: #ffb86c;">"Software Engineer"</span><span style="color: #6272a4;">,</span>
              </div>
              <div class="pl-5">
                <span style="color: #79c0ff;">focus</span><span style="color: #f8f8f2;">: [</span>
                <span style="color: #50fa7b;">"Distributed Systems"</span><span style="color: #6272a4;">, </span>
                <span style="color: #50fa7b;">"Cloud"</span><span style="color: #6272a4;">, </span>
                <span style="color: #50fa7b;">"Go"</span><span style="color: #f8f8f2;">]</span><span style="color: #6272a4;">,</span>
              </div>
              <div class="pl-5">
                <span style="color: #79c0ff;">writing</span><span style="color: #f8f8f2;">: </span>
                <span style="color: #ffb86c;">"about ideas that make systems reliable"</span><span style="color: #6272a4;">,</span>
              </div>
              <div><span style="color: #f8f8f2;">&#125;</span></div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Recent Articles -->
    <section class="pt-7 pb-8" style="border-bottom: 1px solid #2d2f3f;">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-lg font-bold uppercase tracking-widest" style="color: #f8f8f2; letter-spacing: 0.12em;">
          Recent Articles
        </h2>
        <a href="/articles/" class="text-sm font-mono transition-colors" style="color: #8be9fd;"
          onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#8be9fd'">
          All articles →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {posts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
            heroImage={post.data.heroImage}
          />
        ))}
      </div>
    </section>

    <!-- Recent Videos -->
    <section class="pt-7 pb-12">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-lg font-bold uppercase tracking-widest" style="color: #f8f8f2; letter-spacing: 0.12em;">
          Recent Videos
        </h2>
        <a href="/videos/" class="text-sm font-mono transition-colors" style="color: #8be9fd;"
          onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#8be9fd'">
          All videos →
        </a>
      </div>

      {recentVideos.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
          {recentVideos.map(video => (
            <a
              href={video.url}
              target="_blank"
              rel="noopener"
              class="group block rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-200 shadow-lg"
              style="background: #21222c; border: 1px solid #44475a;"
            >
              <div class="relative overflow-hidden" style="aspect-ratio: 16/9;">
                <img src={video.thumbnail} alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent" />
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-11 h-11 rounded-full flex items-center justify-center transition-all duration-200 group-hover:scale-110"
                    style="background: rgba(255,0,0,0.85); box-shadow: 0 4px 20px rgba(255,0,0,0.4);">
                    <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-4">
                <time datetime={video.published} class="text-xs font-mono" style="color: #44475a;">
                  {video.formattedDate}
                </time>
                <h2 class="mt-2 text-sm font-semibold leading-snug line-clamp-2" style="color: #f8f8f2;">
                  {video.title}
                </h2>
                {video.description && (
                  <p class="mt-1.5 text-xs leading-relaxed line-clamp-2" style="color: #6272a4;">
                    {video.description}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm font-mono" style="color: #44475a;">Videos unavailable at build time.</p>
      )}
    </section>

  </div>
</BaseLayout>
