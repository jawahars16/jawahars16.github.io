---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  jsonLd?: object;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const currentPath = Astro.url.pathname;

const nav = [
  { label: 'Articles', href: '/articles/' },
  { label: 'Bytes', href: '/bytes/' },
  { label: 'Videos', href: '/videos/' },
  { label: 'About', href: '/about/' },
];
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jawahar S" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="jawahar.dev" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      html { font-family: 'JetBrains Mono', ui-monospace, 'Cascadia Code', 'Fira Code', monospace; }
    </style>

    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>j</text></svg>"
    />
  </head>

  <body class="min-h-screen flex flex-col" style="background-color: #282a36; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 40px 40px; background-attachment: fixed; color: #f8f8f2;">

    <header class="sticky top-0 z-10" style="background: linear-gradient(135deg, #4f46e5, #7c3aed, #9333ea); box-shadow: 0 2px 16px 0 rgba(99,102,241,0.18);">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a
          href="/"
          class="font-mono text-base font-bold tracking-tight text-white hover:text-white/80 transition-colors" style="letter-spacing: 0.01em; text-shadow: 0 0 18px rgba(255,255,255,0.25);"
        >
          jawahar.dev
        </a>
        <nav aria-label="Main navigation">
          <ul class="flex items-center gap-6">
            {nav.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class:list={[
                    'text-sm transition-colors relative',
                    currentPath.startsWith(href)
                      ? 'text-white font-semibold'
                      : 'text-indigo-200 hover:text-white',
                  ]}
                  aria-current={currentPath.startsWith(href) ? 'page' : undefined}
                >
                  {label}
                  {currentPath.startsWith(href) && (
                    <span class="absolute -bottom-[17px] left-0 right-0 h-0.5 bg-white/70 rounded-t-full" />
                  )}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-24" style="border-top: 1px solid #44475a; background: #21222c;">
      <div class="max-w-5xl mx-auto px-6 py-10">
        <!-- Top row: brand + links -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-8">
          <a href="/" class="font-mono font-bold text-base tracking-tight" style="color: #f8f8f2;">jawahar.dev</a>
          <div class="flex gap-6 text-sm font-mono">
            <a href="/articles/" class="transition-colors" style="color: #6272a4;" onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#6272a4'">Articles</a>
            <a href="/bytes/" class="transition-colors" style="color: #6272a4;" onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#6272a4'">Bytes</a>
            <a href="/videos/" class="transition-colors" style="color: #6272a4;" onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#6272a4'">Videos</a>
            <a href="/about/" class="transition-colors" style="color: #6272a4;" onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#6272a4'">About</a>
          </div>
          <div class="flex gap-5 text-sm font-mono">
            <a href="https://github.com/jawahars16" target="_blank" rel="noopener" class="flex items-center gap-1.5 transition-colors" style="color: #6272a4;" onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#6272a4'">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
              GitHub
            </a>
            <a href="https://www.youtube.com/@jawahars16" target="_blank" rel="noopener" class="flex items-center gap-1.5 transition-colors" style="color: #6272a4;" onmouseover="this.style.color='#f8f8f2'" onmouseout="this.style.color='#6272a4'">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
          </div>
        </div>
        <!-- Divider -->
        <div style="border-top: 1px solid #2d2f3f;"></div>
        <!-- Bottom row: copyright -->
        <div class="flex items-center justify-center mt-6">
          <span class="text-xs font-mono" style="color: #44475a;">&copy; {new Date().getFullYear()} jawahar.dev — All rights reserved</span>
        </div>
      </div>
    </footer>

  </body>
</html>
